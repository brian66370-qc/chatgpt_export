{
  "manifest_version": 3,
  "name": "ChatGPT Markdown Exporter",
  "version": "0.1.0",
  "description": "Export the current ChatGPT conversation to a local Markdown file.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Export ChatGPT conversation",
    "default_popup": "popup.html"
  }
}
